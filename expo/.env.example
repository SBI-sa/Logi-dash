# Supabase Configuration
# Get these values from your Supabase project dashboard: https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Authentication Access Codes (3-tier access system)
# Limited Viewer: PO, Transportation, VAS tabs only (read-only)
EXPO_PUBLIC_VIEWER_PASSWORD=2030
# Full Viewer: All tabs (read-only)
EXPO_PUBLIC_FULL_VIEWER_PASSWORD=2580
# Admin: All tabs with edit permissions
EXPO_PUBLIC_ADMIN_PASSWORD=your_admin_code_here
